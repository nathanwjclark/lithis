# lithis server configuration (local dev matches docker-compose.yml defaults)
LITHIS_ROLE=all                    # api | orchestrator | worker | all
DATABASE_URL=postgres://lithis:lithis-local@localhost:5432/lithis
OBJECT_STORE_URL=http://lithis:lithis-local@localhost:9000
PORT=4400

# Integration tests (deliberately separate from DATABASE_URL — the test
# harness truncates tables, so never point this at a seeded dev database)
# LITHIS_TEST_DATABASE_URL=postgres://lithis:lithis-local@localhost:5432/lithis_test

# Local custody backend (custody module): dotenv-style file holding SECRET
# MATERIAL — one KEY=VALUE per line, # comments allowed, optional quotes.
# Credential records point at entries via custodyBackendRef "env-file:<KEY>";
# rows never store values. Keep this file out of the repo.
#   example line:  SLACK_BOT_TOKEN=xoxb-...
# LITHIS_SECRETS_FILE=/path/to/lithis-secrets.env

# Agent execution (agents module, P7) + the context module's ingest-time
# distill pass (P4)
ANTHROPIC_API_KEY=
# LITHIS_AGENT_MODEL=claude-sonnet-5     # model for resident-agent executor runs

# Context module (P4)
# OPENAI_API_KEY=                        # chunk/query embeddings (text-embedding-3-small); unset -> FTS-only search
# LITHIS_BLOB_DIR=var/blobs              # local blob-storage root, used when OBJECT_STORE_URL is unset
# LITHIS_BLOB_BUCKET=lithis-blobs        # bucket for the Bun.s3 driver when OBJECT_STORE_URL is set
# LITHIS_DISTILL_MODEL=claude-sonnet-5   # model for the one ingest-time distill pass

# Processes module (P8)
# LITHIS_CASCADE_AUTO_WIDTH=3            # rerun cascades wider than this gate as a HumanRequest{cascade_plan}

# Slack delivery + inbound Socket Mode (delivery module + slack connector)
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# Google Workspace connector OAuth client
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Microsoft 365 connector (Entra app registration)
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT_ID=
