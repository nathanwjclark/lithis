# lithis server configuration (local dev matches docker-compose.yml defaults)
LITHIS_ROLE=all                    # api | orchestrator | worker | all
DATABASE_URL=postgres://lithis:lithis-local@localhost:5432/lithis
OBJECT_STORE_URL=http://lithis:lithis-local@localhost:9000
PORT=4400

# Integration tests (deliberately separate from DATABASE_URL — the test
# harness truncates tables, so never point this at a seeded dev database)
# LITHIS_TEST_DATABASE_URL=postgres://lithis:lithis-local@localhost:5432/lithis_test

# Agent execution (required once apps/server agents module is implemented)
ANTHROPIC_API_KEY=

# Slack delivery + inbound Socket Mode (delivery module + slack connector)
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# Google Workspace connector OAuth client
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Microsoft 365 connector (Entra app registration)
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT_ID=
